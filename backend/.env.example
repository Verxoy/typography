SECRET_KEY=change-me

# Битрикс24: входящий вебхук (Приложения → Разработчикам → Входящий вебхук, право CRM)
# Пример: https://ваш-портал.bitrix24.ru/rest/1/xxxxxxxxxxxxxxxx/
BITRIX_WEBHOOK_URL=https://ваш-портал.bitrix24.ru/rest/1/xxxxxxxxxxxxxxxx/
BITRIX_ENABLED=true
# deal = экран «Сделки» (канбан), lead = раздел «Лиды»
BITRIX_CRM_ENTITY=deal
# Если Bitrix недоступен — сохранить копию в data/bitrix_stub/
BITRIX_STUB_FALLBACK=true

# Ссылка в CRM на карточку заявки с макетами (/staff/quotes/QR-…)
# Обычно тот же URL, что и API (Django отдаёт собранный vue-project/dist)
FRONTEND_BASE_URL=http://127.0.0.1:8000
# Для разработки UI через Vite: SERVE_FRONTEND_FROM_DJANGO=false и FRONTEND_BASE_URL=http://127.0.0.1:5173

# Резюме с сайта — только на почту (получатель)
RESUME_NOTIFY_EMAIL=lina.verxoglyadova@gmail.com
# SMTP (для Gmail: smtp.gmail.com, порт 587, пароль приложения)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=ваш@gmail.com
EMAIL_HOST_PASSWORD=пароль-приложения
DEFAULT_FROM_EMAIL=ваш@gmail.com
